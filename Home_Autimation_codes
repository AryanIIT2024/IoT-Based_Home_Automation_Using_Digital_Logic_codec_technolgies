#include <SPI.h>
#include <MFRC522.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// RFID Reader pins (SPI Interface)
#define SS_PIN 10  // SDA (to RFID)
#define RST_PIN 9  // RST (to RFID)

MFRC522 rfid(SS_PIN, RST_PIN);

// LCD on I2C address 0x27 (A4 = SDA, A5 = SCL)
LiquidCrystal_I2C lcd(0x27, 16, 2);  // Change to 0x3F if needed

// Predefined RFID cards
struct Card {
  byte uid[4];
  const char* name;
};

Card authorizedCards[] = {
  {{0xF2, 0xD4, 0xD9, 0x1F}, "Deepak Gupta"},
  {{0x42, 0xDD, 0xFC, 0x1F}, "PATLI KAMRIYA"},
  {{0x82, 0x21, 0xF1, 0x1F}, "ARYAN SRIVASTAVA"}

};
const int numCards = sizeof(authorizedCards) / sizeof(Card);

void setup() {
  Serial.begin(9600);
  SPI.begin();
  rfid.PCD_Init();

  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("Scan Your Card");
}

bool isAuthorized(byte *uid, char *nameBuffer) {
  for (int i = 0; i < numCards; i++) {
    bool match = true;
    for (int j = 0; j < 4; j++) {
      if (authorizedCards[i].uid[j] != uid[j]) {
        match = false;
        break;
      }
    }
    if (match) {
      strcpy(nameBuffer, authorizedCards[i].name);
      return true;
    }
  }
  return false;
}

void loop() {
  if (!rfid.PICC_IsNewCardPresent()) return;
  if (!rfid.PICC_ReadCardSerial()) return;

  char name[20] = "";

  Serial.print("Card UID: ");
  for (byte i = 0; i < rfid.uid.size; i++) {
    Serial.print(rfid.uid.uidByte[i], HEX);
    Serial.print(" ");
  }
  Serial.println();

  if (isAuthorized(rfid.uid.uidByte, name)) {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Welcome:");
    lcd.setCursor(0, 1);
    lcd.print(name);
    Serial.println("Access Granted");
  } else {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Access Denied");
    Serial.println("Access Denied");
  }

  delay(2000);
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Scan Your Card");

  rfid.PICC_HaltA();
}



